# Claude AI (חובה)
ANTHROPIC_API_KEY=sk-ant-...

# YouTube Data API v3 (חובה לחיפוש יוטיוב)
# קבל מ: https://console.cloud.google.com → Enable YouTube Data API v3
YOUTUBE_API_KEY=AIza...

# Serper API - Google Search (חובה לחיפוש ברשת ובטלגרם)
# קבל מ: https://serper.dev (100 חיפושים חינם ביום)
SERPER_API_KEY=...

# Supabase (אופציונלי - לזיכרון ולמידה)
# קבל מ: https://supabase.com → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Port (ברירת מחדל: 8000)
PORT=8000
